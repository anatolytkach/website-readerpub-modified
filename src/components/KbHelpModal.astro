<div class="modal kb-help-modal" id="kb-help-modal" aria-hidden="true">
	<div class="modal-backdrop" data-modal-close></div>
	<div class="modal-content" role="dialog" aria-modal="true" aria-labelledby="kb-help-modal-title">
		<button class="modal-close" type="button" aria-label="Close" data-modal-close>x</button>
		<div class="kb-help-modal-inner">
			<h3 id="kb-help-modal-title">Ask us a question</h3>
			<form class="kb-help-form" method="POST" action="/api/onboarding">
				<label for="kb-your-name">Your name</label>
				<input id="kb-your-name" name="your_name" type="text" required />

				<label for="kb-email">Email</label>
				<input id="kb-email" name="email" type="email" required />

				<label for="kb-category">What is your question about?</label>
				<select id="kb-category" name="category" required>
					<option value="">Select one</option>
					<option value="Technical Issue">Technical Issue</option>
					<option value="Publishing Question">Publishing Question</option>
					<option value="Account Problem">Account Problem</option>
					<option value="Billing">Billing</option>
				</select>

				<label for="kb-notes">Describe your issue</label>
				<textarea id="kb-notes" name="notes" rows="4"></textarea>

				<p class="kb-help-form-error" hidden></p>

				<div class="cta-row kb-help-modal-actions">
					<button class="button" type="submit">Send a message</button>
				</div>
			</form>
		</div>
	</div>
</div>

<script>
	const setupKbHelpModal = () => {
		const helpModal = document.querySelector("#kb-help-modal");
		const helpForm = document.querySelector(".kb-help-form");

		if (!helpModal || !helpForm || helpModal.getAttribute("data-kb-help-ready") === "true") {
			return;
		}

		helpModal.setAttribute("data-kb-help-ready", "true");

		const openButtons = Array.from(document.querySelectorAll('[data-modal-open="#kb-help-modal"]'));
		const formError = helpForm.querySelector(".kb-help-form-error");
		const submitButton = helpForm.querySelector('button[type="submit"]');

		const closeModal = () => {
			helpModal.classList.remove("is-open");
			helpModal.setAttribute("aria-hidden", "true");
		};

		const openModal = () => {
			helpModal.classList.add("is-open");
			helpModal.setAttribute("aria-hidden", "false");
		};

		closeModal();

		openButtons.forEach((button) => {
			button.addEventListener("click", (event) => {
				event.preventDefault();
				if (formError) {
					formError.textContent = "";
					formError.hidden = true;
				}
				openModal();
			});
		});

		helpModal.querySelectorAll("[data-modal-close]").forEach((button) => {
			button.addEventListener("click", closeModal);
		});

		helpForm.addEventListener("submit", async (event) => {
			event.preventDefault();

			const formData = new FormData(helpForm);
			const action = helpForm.getAttribute("action");
			const originalButtonText = submitButton?.textContent || "";

			if (formError) {
				formError.textContent = "";
				formError.hidden = true;
			}
			if (submitButton) {
				submitButton.disabled = true;
				submitButton.textContent = "Sending...";
			}

			try {
				const response = await fetch(action, {
					method: "POST",
					body: formData,
					headers: { Accept: "application/json" },
				});
				const payload = await response.json().catch(() => null);

				if (!response.ok || !payload?.ok) {
					throw new Error(payload?.error || "Could not submit. Try again.");
				}

				closeModal();
				helpForm.reset();
				alert("Thank you, your message has been sent. We will get back to you soon.");
			} catch (error) {
				if (formError) {
					formError.textContent = error instanceof Error ? error.message : "Could not submit. Try again.";
					formError.hidden = false;
				}
			} finally {
				if (submitButton) {
					submitButton.disabled = false;
					submitButton.textContent = originalButtonText;
				}
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				closeModal();
			}
		});
	};

	setupKbHelpModal();
	document.addEventListener("astro:page-load", setupKbHelpModal);
</script>

<style>
	.modal {
		position: fixed;
		inset: 0;
		z-index: 1100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 24px;
	}

	.modal.is-open {
		display: flex;
	}

	.modal-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(20, 23, 31, 0.35);
	}

	.modal-content {
		position: relative;
		z-index: 1;
		display: block;
		width: min(520px, calc(100vw - 32px));
		padding: 40px;
		background: linear-gradient(135deg, var(--card-bg) 0%, var(--card-bg) 15%, #ffffff 100%);
		border: 1px solid var(--border);
		border-radius: 16px;
		box-shadow: 0 24px 70px rgba(20, 23, 31, 0.22);
	}

	.modal-close {
		position: absolute;
		top: 10px;
		right: 10px;
		z-index: 4;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 36px;
		height: 36px;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: #ffffff;
		color: var(--text);
		font: inherit;
		font-size: 20px;
		line-height: 1;
		box-shadow: 0 8px 20px rgba(20, 23, 31, 0.15);
		cursor: pointer;
	}

	.kb-help-modal-inner {
		display: grid;
		gap: 18px;
	}

	.kb-help-modal-inner h3 {
		margin: 0;
		text-align: center;
	}

	.kb-help-form {
		display: grid;
		gap: 10px;
	}

	.kb-help-form label {
		color: var(--text);
		font-size: 15px;
		font-weight: 700;
	}

	.kb-help-form input,
	.kb-help-form select,
	.kb-help-form textarea {
		width: 100%;
		padding: 12px 14px;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: #ffffff;
		color: var(--text);
		font: inherit;
	}

	.kb-help-form textarea {
		resize: vertical;
	}

	.kb-help-form-error {
		margin: 0;
		color: #b42318;
		font-size: 14px;
	}

	.kb-help-modal-actions {
		margin-top: 8px;
	}

	@media (max-width: 640px) {
		.modal {
			padding: 16px;
		}

		.modal-content {
			padding: 34px 22px 24px;
		}
	}
</style>
