---
import type { PageAction } from "../data/pages";

interface Props extends PageAction {
	class?: string;
}

const {
	href,
	label,
	variant = "primary",
	external = false,
	modalTarget,
	class: className = "",
} = Astro.props;

const classes = ["button", variant === "secondary" && "button--secondary", className];
---

{
	modalTarget ? (
		<button class:list={classes} type="button" data-modal-open={modalTarget}>
			{label}
		</button>
	) : (
		<a
			class:list={classes}
			href={href}
			target={external ? "_blank" : undefined}
			rel={external ? "noopener noreferrer" : undefined}
		>
			{label}
		</a>
	)
}
