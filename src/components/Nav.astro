---
import { PUBLISH_URL, SITE_NAME } from "../consts";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => pathname === href;
const solutionLinks = [
	{ href: "/platform", label: "Platform" },
	{ href: "/weread", label: "WeRead" },
	{ href: "/wepub", label: "WePub" },
	{ href: "/webuzz", label: "WeBuzz" },
	{ href: "/booktree", label: "BookTree" },
];
const primaryLinks = [
	{ href: "/weread", label: "Readers" },
	{ href: "/authors", label: "Authors" },
	{ href: "/institutions", label: "Institutions" },
	{ href: "/security", label: "Security" },
	{ href: "/pricing", label: "Pricing" },
];
const isSolutionActive = solutionLinks.some((link) => isActive(link.href));
---

<nav class="nav" aria-label="Primary">
	<div class="nav-brand">
		<img src="/images/logo.svg" alt="" class="site-logo" width="62" height="56" fetchpriority="high" />
		<a class="nav-logo-link" href="/">{SITE_NAME}</a>
	</div>

	<ul class="nav-links">
		{primaryLinks.slice(0, 3).map((link) => (
			<li>
				<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
					{link.label}
				</a>
			</li>
		))}
		<li class:list={["nav-dropdown", isSolutionActive && "nav-dropdown--active"]}>
			<button class="nav-dropdown-toggle" type="button" aria-expanded="false" aria-current={isSolutionActive ? "page" : undefined}>
				Solution
			</button>
			<ul class="nav-dropdown-menu">
				{solutionLinks.map((link) => (
					<li>
						<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</li>
		{primaryLinks.slice(3).map((link) => (
			<li>
				<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
					{link.label}
				</a>
			</li>
		))}
	</ul>

	<div class="nav-actions">
		<a class="button button--secondary nav-signin" href={PUBLISH_URL} target="_blank" rel="noopener noreferrer">Sign in</a>
		<a class="button nav-cta" href="/contact">Get started</a>
		<button class="nav-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false">
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
		</button>
	</div>
</nav>

<div class="nav-overlay" aria-hidden="true">
	<div class="nav-overlay-header">
		<span class="nav-logo">{SITE_NAME}</span>
		<button class="nav-close" type="button" aria-label="Close navigation menu">
			<span class="nav-close-bar"></span>
			<span class="nav-close-bar"></span>
		</button>
	</div>
	<ul class="nav-overlay-links">
		<li><a href={PUBLISH_URL} target="_blank" rel="noopener noreferrer">Sign in</a></li>
		<li><a href="/contact">Get started</a></li>
		<li class="nav-overlay-divider" aria-hidden="true"></li>
		{primaryLinks.map((link) => (
			<li><a href={link.href} class:list={[isActive(link.href) && "is-active"]}>{link.label}</a></li>
		))}
		<li class="nav-overlay-group">
			<span>Solution</span>
			<ul>
				{solutionLinks.map((link) => (
					<li><a href={link.href} class:list={[isActive(link.href) && "is-active"]}>{link.label}</a></li>
				))}
			</ul>
		</li>
	</ul>
</div>

<script is:inline>
	(() => {
		const toggle = document.querySelector(".nav-toggle");
		const overlay = document.querySelector(".nav-overlay");
		const close = document.querySelector(".nav-close");
		const dropdownToggle = document.querySelector(".nav-dropdown-toggle");
		const dropdown = document.querySelector(".nav-dropdown");

		const closeMenu = () => {
			overlay?.classList.remove("nav-overlay--open");
			overlay?.setAttribute("aria-hidden", "true");
			toggle?.setAttribute("aria-expanded", "false");
			document.body.classList.remove("nav-open");
		};

		toggle?.addEventListener("click", () => {
			overlay?.classList.add("nav-overlay--open");
			overlay?.setAttribute("aria-hidden", "false");
			toggle.setAttribute("aria-expanded", "true");
			document.body.classList.add("nav-open");
		});

		close?.addEventListener("click", closeMenu);
		overlay?.addEventListener("click", (event) => {
			if (event.target instanceof Element && event.target.closest("a")) closeMenu();
		});

		dropdownToggle?.addEventListener("click", () => {
			const isOpen = dropdown?.classList.toggle("nav-dropdown--open");
			dropdownToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
		});

		document.addEventListener("click", (event) => {
			if (!(event.target instanceof Element)) return;
			if (!event.target.closest(".nav-dropdown")) {
				dropdown?.classList.remove("nav-dropdown--open");
				dropdownToggle?.setAttribute("aria-expanded", "false");
			}
		});

		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape") {
				closeMenu();
				dropdown?.classList.remove("nav-dropdown--open");
				dropdownToggle?.setAttribute("aria-expanded", "false");
			}
		});
	})();
</script>
