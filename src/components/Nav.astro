---
import { PUBLISH_URL, SITE_NAME } from "../consts";

const pathname = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isActive = (href: string) => pathname === href;
const solutionLinks = [
	{ href: "/platform", label: "Platform" },
	{ href: "/wepub", label: "WePub" },
	{ href: "/weread", label: "WeRead" },
	{ href: "/webuzz", label: "WeBuzz" },
	{ href: "/wetalk", label: "WeTalk" },
	{ href: "/booktree", label: "BookTree" },
	{ href: "/scribe", label: "Scribe" },
];
const primaryLinks = [
	{ href: "/weread", label: "Readers" },
	{ href: "/authors", label: "Authors" },
	{ href: "/institutions", label: "Institutions" },
	{ href: "/security", label: "Security" },
	{ href: "/pricing", label: "Pricing" },
	{ href: "/about", label: "About" },
];
const hasActivePrimaryLink = primaryLinks.some((link) => isActive(link.href));
const isSolutionActive = !hasActivePrimaryLink && solutionLinks.some((link) => isActive(link.href));
---

<nav class="nav" aria-label="Primary">
	<div class="nav-brand">
		<img src="/images/logo.svg" alt="" class="site-logo" width="44" height="44" fetchpriority="high" />
		<a class="nav-logo-link" href="/">{SITE_NAME}</a>
	</div>

	<ul class="nav-links">
		{primaryLinks.slice(0, 3).map((link) => (
			<li>
				<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
					{link.label}
				</a>
			</li>
		))}
		<li class:list={["nav-dropdown", isSolutionActive && "nav-dropdown--active"]}>
			<button class="nav-dropdown-toggle" type="button" aria-expanded="false" aria-current={isSolutionActive ? "page" : undefined}>
				Solution
			</button>
			<ul class="nav-dropdown-menu">
				{solutionLinks.map((link) => (
					<li>
						<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</li>
		{primaryLinks.slice(3).map((link) => (
			<li>
				<a href={link.href} class:list={[isActive(link.href) && "is-active"]} aria-current={isActive(link.href) ? "page" : undefined}>
					{link.label}
				</a>
			</li>
		))}
	</ul>

	<div class="nav-actions">
		<a class="button button--secondary nav-signin" href={PUBLISH_URL} target="_blank" rel="noopener noreferrer">Sign in</a>
		<a class="button nav-cta" href="/contact">Get started</a>
		<button class="nav-toggle" type="button" aria-label="Open navigation menu" aria-expanded="false">
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
			<span class="nav-toggle-bar"></span>
		</button>
	</div>
</nav>

<div class="nav-overlay" aria-hidden="true">
	<div class="nav-overlay-header">
		<span class="nav-logo">{SITE_NAME}</span>
		<button class="nav-close" type="button" aria-label="Close navigation menu">
			<span class="nav-close-bar"></span>
			<span class="nav-close-bar"></span>
		</button>
	</div>
	<ul class="nav-overlay-links">
		{primaryLinks.slice(0, 3).map((link) => (
			<li><a href={link.href} class:list={[isActive(link.href) && "is-active"]}>{link.label}</a></li>
		))}
		<li class="nav-overlay-group">
			<span>Solution</span>
			<ul>
				{solutionLinks.map((link) => (
					<li><a href={link.href} class:list={[isActive(link.href) && "is-active"]}>{link.label}</a></li>
				))}
			</ul>
		</li>
		{primaryLinks.slice(3).map((link) => (
			<li><a href={link.href} class:list={[isActive(link.href) && "is-active"]}>{link.label}</a></li>
		))}
		<li class="nav-overlay-divider" aria-hidden="true"></li>
		<li><a href={PUBLISH_URL} target="_blank" rel="noopener noreferrer">Sign in</a></li>
		<li><a href="/contact">Get started</a></li>
	</ul>
</div>

<script is:inline>
	(() => {
		const normalizePath = (path) => path.replace(/\/+$/, "") || "/";

		const updateActiveLink = () => {
			const currentPath = normalizePath(window.location.pathname);
			const hasActivePrimaryLink = Array.from(document.querySelectorAll(".nav-links > li > a")).some((link) => {
				const href = link.getAttribute("href");
				return href && !href.startsWith("http") && normalizePath(href) === currentPath;
			});

			document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
				dropdown.classList.remove("nav-dropdown--active");
				dropdown.querySelector(".nav-dropdown-toggle")?.removeAttribute("aria-current");
			});

			document.querySelectorAll(".nav a, .nav-overlay a").forEach((link) => {
				link.classList.remove("is-active");
				link.removeAttribute("aria-current");

				const href = link.getAttribute("href");
				if (!href || href.startsWith("http")) return;

				if (normalizePath(href) === currentPath) {
					link.classList.add("is-active");
					link.setAttribute("aria-current", "page");

					const dropdown = link.closest(".nav-dropdown");
					if (dropdown && !hasActivePrimaryLink) {
						dropdown.classList.add("nav-dropdown--active");
						dropdown.querySelector(".nav-dropdown-toggle")?.setAttribute("aria-current", "page");
					}
				}
			});
		};

		const closeMenu = () => {
			document.querySelectorAll(".nav-overlay").forEach((overlay) => {
				overlay.classList.remove("nav-overlay--open");
				overlay.setAttribute("aria-hidden", "true");
			});
			document.querySelectorAll(".nav-toggle").forEach((toggle) => {
				toggle.setAttribute("aria-expanded", "false");
			});
			document.body.classList.remove("nav-open");
		};

		const closeDropdown = () => {
			document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
				dropdown.classList.remove("nav-dropdown--open");
				dropdown.querySelector(".nav-dropdown-toggle")?.setAttribute("aria-expanded", "false");
			});
		};

		const dismissDropdown = (dropdown) => {
			closeDropdown();
			dropdown?.classList.add("nav-dropdown--dismissed");
			const activeElement = document.activeElement;
			if (activeElement instanceof HTMLElement) activeElement.blur();
		};

		const setupNav = () => {
			const toggle = document.querySelector(".nav-toggle");
			const overlay = document.querySelector(".nav-overlay");
			const close = document.querySelector(".nav-close");
			const dropdownToggle = document.querySelector(".nav-dropdown-toggle");
			const dropdown = document.querySelector(".nav-dropdown");

			if (toggle && toggle.getAttribute("data-nav-ready") !== "true") {
				toggle.setAttribute("data-nav-ready", "true");
				toggle.addEventListener("click", () => {
					overlay?.classList.add("nav-overlay--open");
					overlay?.setAttribute("aria-hidden", "false");
					toggle.setAttribute("aria-expanded", "true");
					document.body.classList.add("nav-open");
				});
			}

			if (close && close.getAttribute("data-nav-ready") !== "true") {
				close.setAttribute("data-nav-ready", "true");
				close.addEventListener("click", closeMenu);
			}

			if (overlay && overlay.getAttribute("data-nav-ready") !== "true") {
				overlay.setAttribute("data-nav-ready", "true");
				overlay.addEventListener("click", (event) => {
					if (event.target instanceof Element && event.target.closest("a")) closeMenu();
				});
			}

			if (dropdownToggle && dropdownToggle.getAttribute("data-nav-ready") !== "true") {
				dropdownToggle.setAttribute("data-nav-ready", "true");
				dropdownToggle.addEventListener("click", () => {
					dropdown?.classList.remove("nav-dropdown--dismissed");
					const isOpen = dropdown?.classList.toggle("nav-dropdown--open");
					dropdownToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
				});
			}

			updateActiveLink();
		};

		if (document.documentElement.getAttribute("data-nav-global-ready") !== "true") {
			document.documentElement.setAttribute("data-nav-global-ready", "true");

			document.addEventListener("click", (event) => {
				if (!(event.target instanceof Element)) return;
				const openOverlay = document.querySelector(".nav-overlay.nav-overlay--open");
				if (openOverlay && !event.target.closest(".nav-overlay") && !event.target.closest(".nav-toggle")) {
					closeMenu();
				}

				const activeDropdown = event.target.closest(".nav-dropdown");
				if (event.target.closest(".nav-dropdown-menu a")) {
					dismissDropdown(activeDropdown);
					return;
				}
				if (!activeDropdown) {
					closeDropdown();
				}
			});

			document.addEventListener("pointerover", (event) => {
				if (!(event.target instanceof Element)) return;
				if (event.target.closest(".nav-dropdown-toggle")) {
					event.target.closest(".nav-dropdown")?.classList.remove("nav-dropdown--dismissed");
				}
			});

			document.addEventListener("keydown", (event) => {
				if (event.key === "Escape") {
					closeMenu();
					closeDropdown();
				}
			});

			document.addEventListener("astro:page-load", setupNav);
			document.addEventListener("astro:page-load", updateActiveLink);
			document.addEventListener("astro:before-swap", closeMenu);
			document.addEventListener("astro:before-swap", closeDropdown);
		}

		setupNav();
		updateActiveLink();
	})();
</script>
