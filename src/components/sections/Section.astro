---
import type { SectionTone } from "../../data/pages";

interface Props {
	id?: string;
	tone?: SectionTone;
	kicker?: string;
	title?: string;
	body?: string;
	hasMedia?: boolean;
	class?: string;
}

const {
	id,
	tone = "white",
	kicker,
	title,
	body,
	hasMedia = false,
	class: className = "",
} = Astro.props;
const resolvedTone = hasMedia ? "white" : tone;
const hasTitleSlot = Astro.slots.has("title");
const hasBodySlot = Astro.slots.has("body");
---

<section id={id} class:list={["section", `section--${resolvedTone}`, hasMedia && "section--with-media", className]}>
	{(kicker || title || hasTitleSlot || body || hasBodySlot) && (
		<header class="section-header">
			{kicker && <p class="section-kicker">{kicker}</p>}
			{(title || hasTitleSlot) && <h2>{hasTitleSlot ? <slot name="title" /> : title}</h2>}
			{hasBodySlot ? <p class="section-lead"><slot name="body" /></p> : body && <p class="section-lead">{body}</p>}
		</header>
	)}
	<slot />
</section>
