---
import ActionLink from "../ActionLink.astro";
import type { PageAction } from "../../data/pages";

interface Props {
	title: string;
	body?: string;
	actions: PageAction[];
	class?: string;
}

const { title, body, actions, class: className = "" } = Astro.props;
const hasBodySlot = Astro.slots.has("body");
---

<section class:list={["cta-block", "section--dark", className]}>
	<div class="cta-block-copy">
		<h2>{title}</h2>
		{(hasBodySlot || body) && <p>{hasBodySlot ? <slot name="body" /> : body}</p>}
	</div>
	<div class="cta-row">
		{actions.map((action) => <ActionLink {...action} />)}
	</div>
</section>
