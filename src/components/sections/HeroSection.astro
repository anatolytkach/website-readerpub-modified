---
import ActionLink from "../ActionLink.astro";
import type { PageAction } from "../../data/pages";

interface Props {
	eyebrow?: string;
	title?: string;
	lead?: string;
	body?: string;
	image?: string;
	imageAlt?: string;
	actions?: PageAction[];
	spacerBackgroundPositionY?: string;
	class?: string;
}

const {
	eyebrow,
	title,
	lead,
	body,
	image,
	imageAlt = "",
	actions = [],
	spacerBackgroundPositionY,
	class: className = "",
} = Astro.props;

const spacerBackgroundPositionPercent = spacerBackgroundPositionY?.endsWith("%")
	? Number.parseFloat(spacerBackgroundPositionY)
	: undefined;
const shouldFlipSpacerBackground =
	typeof spacerBackgroundPositionPercent === "number" &&
	Number.isFinite(spacerBackgroundPositionPercent) &&
	Math.floor(spacerBackgroundPositionPercent / 9) % 2 === 1;
const spacerStyle = [
	spacerBackgroundPositionY && `--hero-background-spacer-position-y: ${spacerBackgroundPositionY};`,
	shouldFlipSpacerBackground && "--hero-background-spacer-scale-x: -1;",
]
	.filter(Boolean)
	.join("") || undefined;
const hasEyebrowSlot = Astro.slots.has("eyebrow");
const hasTitleSlot = Astro.slots.has("title");
const hasLeadSlot = Astro.slots.has("lead");
const hasBodySlot = Astro.slots.has("body");
---

<section class:list={["hero-section", "section--white", image && "section--with-media", className]}>
	<div class="hero-copy">
		{(eyebrow || hasEyebrowSlot) && (
			<p class="section-kicker">
				{hasEyebrowSlot ? <slot name="eyebrow" /> : eyebrow}
			</p>
		)}
		{(title || hasTitleSlot) && <h1>{hasTitleSlot ? <slot name="title" /> : title}</h1>}
		<slot name="tagline" />
		{(lead || hasLeadSlot) && <p class="hero-lead">{hasLeadSlot ? <slot name="lead" /> : lead}</p>}
		{hasBodySlot ? <div class="hero-body"><slot name="body" /></div> : body && <p class="hero-body">{body}</p>}
		<slot />
		{actions.length > 0 && (
			<div class="cta-row">
				{actions.map((action) => <ActionLink {...action} />)}
			</div>
		)}
	</div>
	{image && (
		<div class="hero-media" data-hero-load-reveal>
			<img
				class="image-block hero-image"
				src={image}
				alt={imageAlt}
				loading="eager"
				decoding="async"
				width="1024"
				height="900"
			/>
		</div>
	)}
</section>

<section class="hero-background-spacer" aria-hidden="true" style={spacerStyle}></section>

<script>
	let heroBackgroundSpacerObserver;

	const syncHeroBackgroundSpacer = (hero) => {
		const spacer = hero.nextElementSibling;

		if (!spacer?.classList.contains("hero-background-spacer")) {
			return;
		}

		const heroImage = hero.querySelector(".hero-image");
		const referenceHeight =
			heroImage?.getBoundingClientRect().height || hero.getBoundingClientRect().height;

		if (referenceHeight > 0) {
			spacer.style.setProperty("--hero-background-spacer-height", `${Math.round(referenceHeight * 0.3)}px`);
		}
	};

	const syncHeroBackgroundSpacers = () => {
		const heroes = document.querySelectorAll(".hero-section");

		if (heroBackgroundSpacerObserver) {
			heroBackgroundSpacerObserver.disconnect();
		}

		if ("ResizeObserver" in window) {
			heroBackgroundSpacerObserver = new ResizeObserver((entries) => {
				for (const entry of entries) {
					const hero = entry.target.classList.contains("hero-section")
						? entry.target
						: entry.target.closest(".hero-section");

					if (hero) {
						syncHeroBackgroundSpacer(hero);
					}
				}
			});
		}

		for (const hero of heroes) {
			const heroImage = hero.querySelector(".hero-image");

			syncHeroBackgroundSpacer(hero);
			heroBackgroundSpacerObserver?.observe(hero);
			heroImage && heroBackgroundSpacerObserver?.observe(heroImage);
			heroImage?.addEventListener("load", () => syncHeroBackgroundSpacer(hero), { once: true });
		}
	};

	document.addEventListener("astro:page-load", syncHeroBackgroundSpacers);
	window.addEventListener("load", syncHeroBackgroundSpacers, { once: true });
	window.addEventListener("resize", syncHeroBackgroundSpacers, { passive: true });
	syncHeroBackgroundSpacers();
</script>
