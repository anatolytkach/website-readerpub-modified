---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CardGrid from "../components/CardGrid.astro";
import CtaBlock from "../components/sections/CtaBlock.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import Section from "../components/sections/Section.astro";
import SectionIcon from "../components/SectionIcon.astro";
import { PUBLISH_URL, SITE_NAME } from "../consts";

const publishAction = { label: "Publish with WePub", href: PUBLISH_URL, external: true };
const pricingAction = { label: "See pricing", href: "/pricing", variant: "secondary" as const };
---

<Base
	title={`WePub | ${SITE_NAME}`}
	description="WePub helps authors and publishers create browser-readable books that remain connected to readers, discussion and discovery after release."
>
	<HeroSection
		eyebrow="WePub"
		lead="Most publishing systems are built to distribute files through marketplaces, surrendering the book audience to the marketplace."
		image="/images/wepub.webp"
		imageAlt="WePub publishing workflow from manuscript to live book"
		actions={[publishAction, pricingAction]}
		spacerBackgroundPositionY="18%"
	>
		<Fragment slot="title"><span style="color: var(--accent);">WePub:</span><br />Publish to readers, you never lose.</Fragment>
		<Fragment slot="body">ReaderPub turns books into living web assets: readable, searchable, discussable and connected, so authors and publishers achieve strategic distribution.</Fragment>
	</HeroSection>

	<Section
		tone="gray"
		class="wepub-old-model-section"
		title="The old model just creates book files for download"
		body="A file-based model can distribute a book, but it usually separates the author from the reader."
	>
		<CardGrid columns="2">
			<Card
				title="Problem"
				body="Books are packaged as files and handed to marketplaces that own discovery, customer access and most of the data."
			/>
			<Card
				title="Why it fails"
				body="The sale ends the relationship. The author gets distribution, but the platform keeps the audience."
			/>
		</CardGrid>
	</Section>

	<Section
		tone="white"
		title="The new model builds direct web presence"
		body="WePub treats a book as a web publication that can be read, found, discussed and connected to the author over time."
	>
		<CardGrid columns="3" class="wepub-source-icon-grid">
			<article class="card icon-grid-card">
				<SectionIcon type="publisher" title="Web-native book pages" />
				<div class="icon-grid-card-copy">
					<h3>Web-native book pages</h3>
					<p>Each title can live as a readable web asset, not only as a downloadable package.</p>
				</div>
			</article>
			<article class="card icon-grid-card">
				<SectionIcon type="author" title="Author-centered publishing" />
				<div class="icon-grid-card-copy">
					<h3>Author-centered publishing</h3>
					<p>The author's presence stays connected to the work and to the people reading it.</p>
				</div>
			</article>
			<article class="card icon-grid-card">
				<SectionIcon type="fan" title="Reader connection" />
				<div class="icon-grid-card-copy">
					<h3>Reader connection</h3>
					<p>Discussion and activity remain attached to books and authors after publication.</p>
				</div>
			</article>
		</CardGrid>
	</Section>

		<Section tone="white" class="wepub-path-section" title="What changes when you publish on ReaderPub">
		<div class="wepub-comparison-grid">
			<article class="card wepub-list-card wepub-old-path-card">
				<div class="card-copy">
					<h3>Old publishing path</h3>
					<ul class="wepub-model-list">
						<li>Prepare a file</li>
						<li>Upload to a marketplace</li>
						<li>Let the platform own discovery and customer access</li>
						<li>Watch reader activity disappear after purchase</li>
					</ul>
				</div>
			</article>
			<article class="card wepub-list-card wepub-readerpub-path-card">
				<div class="card-copy">
					<h3><span>ReaderPub</span> path</h3>
					<ul class="wepub-model-list">
						<li>Create a browser-readable publication</li>
						<li>Build an author-centered web presence</li>
						<li>Keep reader relationships connected</li>
						<li>Support discussion and future work around the book</li>
					</ul>
				</div>
			</article>
		</div>
		<div class="wepub-start-grid">
			<article class="card wepub-start-card">
				<div class="card-copy">
					<h3>What you get</h3>
					<p class="wepub-start-lede">Everything you need to publish, monetize, and grow a direct audience.</p>
					<ul class="wepub-start-list">
						<li>A fast web edition readers can open instantly.</li>
						<li>Direct sales to connected readers.</li>
						<li>Low 5% commission on sales.</li>
						<li>Fan clubs for every book and author.</li>
						<li>Analytics for sales and engagement.</li>
						<li>Optional production-ready EPUB output.</li>
					</ul>
				</div>
			</article>
			<article class="card wepub-start-card">
				<div class="card-copy">
					<h3>How publishing works</h3>
					<p class="wepub-start-lede">A simple workflow from manuscript to live web edition.</p>
					<ol class="wepub-start-list">
						<li>Share your manuscript (Word, or EPUB).</li>
						<li>We prepare your web edition and metadata.</li>
						<li>You define sales and fan-club options.</li>
						<li>Your book goes live &mdash; with analytics from day one.</li>
					</ol>
					<p class="wepub-start-lede wepub-compat-lede">
						Compatible with WeRead for web reading and BookTree for organizing sources.
					</p>
				</div>
			</article>
		</div>
	</Section>

	<Section tone="green" class="wepub-economics-section" title="Better economics, stronger connections, longer-lasting value">
		<CardGrid columns="3">
			<Card title="Lower commission" body="ReaderPub uses a 5% platform commission for direct sales." />
			<Card
				title="Better reader connection"
				body="Reader relationships stay connected to the author instead of disappearing into a marketplace account."
			/>
			<Card
				title="Longer book lifecycle"
				body="Books remain active as web assets through discovery, discussion and future author activity."
			/>
		</CardGrid>
	</Section>

	<Section
		tone="white"
		class="wepub-infrastructure-section"
		title="Publishing infrastructure built for the web"
		body="WePub combines secure publishing, browser delivery, direct sales and audience visibility inside a single publishing workflow."
	>
		<CardGrid columns="3">
			<Card title="Web-native publishing" body="Publish books as web destinations rather than isolated downloads." />
			<Card title="Reader visibility" body="Maintain visibility into publication activity after release." />
			<Card title="Anti-piracy" body="Protect access through obfuscated web delivery." />
			<Card title="Direct sales" body="Build direct commercial relationships with readers." />
			<Card title="EPUB generation" body="Generate EPUB editions when external distribution requires them." />
			<Card title="Long-term engagement" body="Keep publications connected to readers after launch." />
		</CardGrid>
	</Section>

	<Section
		tone="green"
		title="From digital files to living web assets"
		body="ReaderPub helps publishers transform books and knowledge publications into living web assets that remain active after release."
		>
			<CardGrid columns="4">
				<Card icon="readerBook" title="Readers" body="Continue engaging with the publication." />
				<Card icon="author" title="Authors" body="Maintain stronger reader relationships." />
				<Card icon="publisher" title="Publishers" body="Gain visibility beyond the moment of sale." />
				<Card icon="library" title="Institutions" body="Publish knowledge that remains discoverable and useful over time." />
			</CardGrid>
		</Section>

	<CtaBlock
		title="Publish living web assets."
		body="Move beyond file delivery and build publications that remain alive after release."
		actions={[publishAction, pricingAction]}
	/>
</Base>

<style>
	.wepub-comparison-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		width: 100%;
	}

	:global(.wepub-old-model-section .section-header),
	:global(.wepub-old-model-section .section-header h2),
	:global(.wepub-old-model-section .section-lead) {
		max-width: none;
		width: 100%;
	}

	@media (min-width: 901px) {
		:global(.wepub-old-model-section .section-header h2) {
			font-size: clamp(1.9rem, 3vw, 2.08rem);
			white-space: nowrap;
		}

		:global(.wepub-old-model-section .section-lead) {
			font-size: clamp(1rem, 1.55vw, 1.08rem);
			white-space: nowrap;
		}
	}

	.wepub-start-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		width: 100%;
	}

	.wepub-start-card {
		--card-tint: #fcfaf8;
		background: var(--button-light-bg);
		min-height: 0;
	}

	.wepub-start-lede {
		color: var(--accent);
		font-size: 1.125rem;
		line-height: 1.45;
	}

	.wepub-start-list {
		display: grid;
		gap: 10px;
		padding-left: 1.15rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.5;
	}

	ul.wepub-start-list,
	ul.wepub-start-list li {
		list-style: disc;
	}

	ol.wepub-start-list,
	ol.wepub-start-list li {
		list-style: decimal;
	}

	.wepub-start-list li::marker {
		color: var(--accent);
	}

	.wepub-compat-lede {
		margin-top: 0;
	}

	.wepub-list-card {
		min-height: 0;
	}

	.wepub-old-path-card {
		background: var(--card-bg);
	}

	.wepub-old-path-card .wepub-model-list li::marker {
		color: var(--text);
	}

	.wepub-readerpub-path-card {
		background: linear-gradient(135deg, #eef6f5 0%, #eef6f5 18%, var(--card-bg) 100%);
	}

	.wepub-readerpub-path-card h3 span {
		color: var(--accent);
	}

	:global(.section.wepub-path-section) {
		padding-top: calc(var(--section-padding) * 0.4375) !important;
	}

	@media (orientation: portrait) {
		:global(.section.wepub-path-section) {
			padding-top: var(--section-padding) !important;
		}
	}

	:global(.wepub-economics-section .card) {
		--card-tint: #fbfaf8;
	}

	:global(.wepub-infrastructure-section .card) {
		--card-tint: #fcfaf8 !important;
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 18%, #ffffff 100%) !important;
	}

	.wepub-model-list {
		display: grid;
		gap: 10px;
		padding-left: 1.15rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.5;
	}

	.wepub-model-list li::marker {
		color: var(--accent);
	}

	.wepub-supporting-text {
		max-width: 760px;
		color: var(--accent);
		font-size: 1.125rem;
		line-height: 1.45;
	}

	:global(.wepub-source-icon-grid .card.icon-grid-card) {
		display: grid !important;
		grid-template-columns: var(--card-icon-column) minmax(0, 1fr) !important;
		column-gap: var(--card-icon-gap) !important;
		row-gap: 16px !important;
		align-items: flex-start;
		width: 100%;
	}

	:global(.wepub-source-icon-grid .icon-grid-card-copy) {
		display: contents;
	}

	:global(.wepub-source-icon-grid .icon-grid-card > .section-icon) {
		grid-column: 1;
		grid-row: 1;
		align-self: center;
		width: var(--card-inline-icon-size) !important;
		height: var(--card-inline-icon-size) !important;
	}

	:global(.wepub-source-icon-grid .icon-grid-card .icon-grid-card-copy > h3) {
		grid-column: 2;
		grid-row: 1;
		align-self: center;
		margin: 0;
	}

	:global(.wepub-source-icon-grid .icon-grid-card .icon-grid-card-copy > p) {
		grid-column: 1 / -1;
	}

	@media (max-width: 900px) {
		.wepub-comparison-grid,
		.wepub-start-grid {
			grid-template-columns: 1fr;
		}

		.wepub-model-list,
		.wepub-start-list {
			text-align: left;
		}

		:global(.wepub-source-icon-grid .icon-grid-card-copy) {
			display: grid;
			gap: 10px;
		}
	}
</style>
