---
import Base from "../layouts/Base.astro";
import CtaBlock from "../components/sections/CtaBlock.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import { BOOKS_URL, PUBLISH_URL, SITE_NAME } from "../consts";
---

<Base
	title={`Terms of Service and Privacy Policy | ${SITE_NAME}`}
	description="ReaderPub and WeBuzz Terms of Service and Privacy Policy."
>
	<HeroSection
		class="terms-hero"
		title="ReaderPub Terms of Service and Privacy Policy"
		image="/images/terms.webp"
		imageAlt="ReaderPub terms of service and privacy policy"
		spacerBackgroundPositionY="100%"
	>
		<Fragment slot="body">
			<p class="legal-updated">Last Updated: June 2026</p>
			<p class="terms-hero-green">Welcome to ReaderPub and WeBuzz.</p>
			<p class="terms-hero-green">
				ReaderPub is a platform for reading, publishing, and discovering books. WeBuzz is the
				community associated with ReaderPub, allowing readers, authors, and publishers to connect
				and interact.
			</p>
			<p>
				By accessing or using ReaderPub, WeBuzz, or any related services (collectively, the
				"Service"), you agree to these Terms of Service and Privacy Policy.
			</p>
		</Fragment>
	</HeroSection>

	<article class="section section--white legal-page">
		<section class="legal-major-section">
			<h2>Terms of Service</h2>

			<div class="legal-block">
				<h3>1. Eligibility</h3>
				<p>
					You must be at least 13 years old, or the minimum age required by the laws of your
					jurisdiction, to use the Service.
				</p>
				<p>
					By using the Service, you represent that you have the legal capacity to enter into this
					agreement.
				</p>
			</div>

			<div class="legal-block">
				<h3>2. Your Account</h3>
				<p>Some features require an account.</p>
				<p>You are responsible for:</p>
				<ul class="bullets">
					<li>maintaining the security of your account;</li>
					<li>protecting your password and login credentials;</li>
					<li>all activities conducted through your account.</li>
				</ul>
				<p>You agree to provide accurate and current information.</p>
				<p>
					We may suspend or terminate accounts that contain false information, violate these Terms,
					or present security risks.
				</p>
			</div>

			<div class="legal-block">
				<h3>3. Acceptable Use</h3>
				<p>You agree not to:</p>
				<ul class="bullets">
					<li>violate any applicable law or regulation;</li>
					<li>infringe copyrights, trademarks, or other intellectual property rights;</li>
					<li>upload malicious software or harmful code;</li>
					<li>interfere with the operation or security of the Service;</li>
					<li>attempt unauthorized access to systems or accounts;</li>
					<li>engage in fraud, impersonation, or deceptive conduct;</li>
					<li>distribute spam or unsolicited commercial communications;</li>
					<li>harass, threaten, stalk, or abuse other users;</li>
					<li>use automated tools to scrape, harvest, or copy content without permission.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>4. Books and Published Content</h3>
				<p>
					ReaderPub allows authors, publishers, institutions, and rights holders to publish and
					distribute content.
				</p>
				<p>You retain ownership of content that you submit to the Service.</p>
				<p>
					By publishing content on ReaderPub, you grant ReaderPub a non-exclusive, worldwide,
					royalty-free license to host, store, reproduce, display, distribute, index, promote, and
					make available that content as necessary to operate and improve the Service.
				</p>
				<p>
					This license remains in effect until the content is removed from the Service, except
					where retention is reasonably necessary for legal, operational, security, archival, or
					backup purposes.
				</p>
				<p>You represent and warrant that you have all necessary rights to publish any content you submit.</p>
			</div>

			<div class="legal-block">
				<h3>5. Public Domain Works</h3>
				<p>ReaderPub may host works that are in the public domain.</p>
				<p>ReaderPub does not claim ownership of public domain materials.</p>
				<p>
					ReaderPub may create enhanced editions, metadata, formatting, illustrations, covers,
					indexes, summaries, or other value-added features associated with public domain works.
					Ownership of such enhancements remains with ReaderPub or the applicable rights holder.
				</p>
			</div>

			<div class="legal-block">
				<h3>6. WeBuzz Community Features</h3>
				<p>WeBuzz may provide community features including:</p>
				<ul class="bullets">
					<li>user profiles;</li>
					<li>activity feeds;</li>
					<li>following and follower relationships;</li>
					<li>book reviews;</li>
					<li>ratings;</li>
					<li>comments;</li>
					<li>reading recommendations;</li>
					<li>literary discussions;</li>
					<li>reader groups;</li>
					<li>author communities;</li>
					<li>messaging and communication features;</li>
					<li>other social and community tools.</li>
				</ul>
				<p>Use of community features is subject to these Terms.</p>
			</div>

			<div class="legal-block">
				<h3>7. User-Generated Content</h3>
				<p>Users may publish content including:</p>
				<ul class="bullets">
					<li>posts;</li>
					<li>comments;</li>
					<li>reviews;</li>
					<li>profile information;</li>
					<li>images;</li>
					<li>recommendations;</li>
					<li>discussion content;</li>
					<li>community submissions.</li>
				</ul>
				<p>You retain ownership of your content.</p>
				<p>
					By posting content through WeBuzz, you grant ReaderPub a non-exclusive, worldwide,
					royalty-free license to host, display, reproduce, distribute, promote, and make available
					such content for the operation and promotion of the Service.
				</p>
				<p>You are solely responsible for content you publish.</p>
			</div>

			<div class="legal-block">
				<h3>8. Community Standards</h3>
				<p>You may not post content that:</p>
				<ul class="bullets">
					<li>is unlawful;</li>
					<li>infringes intellectual property rights;</li>
					<li>promotes violence or criminal activity;</li>
					<li>contains threats, harassment, or targeted abuse;</li>
					<li>contains hate speech directed at protected groups;</li>
					<li>contains malware or harmful code;</li>
					<li>impersonates another person or organization;</li>
					<li>is fraudulent, deceptive, or misleading;</li>
					<li>constitutes spam or manipulation of platform features.</li>
				</ul>
				<p>ReaderPub may remove content or restrict accounts that violate these standards.</p>
			</div>

			<div class="legal-block">
				<h3>9. Reviews and Ratings</h3>
				<p>Reviews and ratings should reflect genuine opinions and experiences.</p>
				<p>
					ReaderPub may remove reviews or ratings that are fraudulent, manipulated, abusive,
					misleading, or intended to artificially influence rankings or visibility.
				</p>
			</div>

			<div class="legal-block">
				<h3>10. Moderation</h3>
				<p>ReaderPub may use automated systems and human review to identify:</p>
				<ul class="bullets">
					<li>spam;</li>
					<li>abuse;</li>
					<li>fraud;</li>
					<li>security threats;</li>
					<li>policy violations.</li>
				</ul>
				<p>
					We reserve the right to remove content, limit visibility, suspend features, restrict
					accounts, or terminate access when necessary to protect users and the integrity of the
					Service.
				</p>
			</div>

			<div class="legal-block">
				<h3>11. Intellectual Property</h3>
				<p>
					The ReaderPub and WeBuzz names, logos, software, design elements, databases, features,
					and platform infrastructure are owned by ReaderPub or its licensors and are protected by
					applicable intellectual property laws.
				</p>
				<p>
					Except as expressly permitted, you may not copy, reproduce, modify, distribute, reverse
					engineer, or create derivative works from the Service.
				</p>
			</div>

			<div class="legal-block">
				<h3>12. Copyright Complaints</h3>
				<p>ReaderPub respects intellectual property rights.</p>
				<p>If you believe content available through the Service infringes your copyright, please contact:</p>
				<p><a href="mailto:support@reader.pub">support@reader.pub</a></p>
				<p>Your notice should include:</p>
				<ul class="bullets">
					<li>identification of the copyrighted work;</li>
					<li>identification of the allegedly infringing material;</li>
					<li>your contact information;</li>
					<li>a statement of good-faith belief that the use is unauthorized;</li>
					<li>a statement that the information provided is accurate.</li>
				</ul>
				<p>ReaderPub may remove or restrict access to content while investigating claims.</p>
			</div>

			<div class="legal-block">
				<h3>13. Service Availability</h3>
				<p>The Service is provided on an "as available" basis.</p>
				<p>
					We may modify, suspend, discontinue, or update any part of the Service at any time without
					prior notice.
				</p>
				<p>We do not guarantee uninterrupted availability.</p>
			</div>

			<div class="legal-block">
				<h3>14. Disclaimer of Warranties</h3>
				<p>To the fullest extent permitted by law, the Service is provided "as is" and "as available."</p>
				<p>ReaderPub disclaims all warranties, whether express or implied, including warranties of:</p>
				<ul class="bullets">
					<li>merchantability;</li>
					<li>fitness for a particular purpose;</li>
					<li>non-infringement;</li>
					<li>uninterrupted availability;</li>
					<li>accuracy or reliability of content.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>15. Limitation of Liability</h3>
				<p>
					To the maximum extent permitted by law, ReaderPub, WeBuzz, their operators, affiliates,
					employees, contractors, and licensors shall not be liable for any indirect, incidental,
					consequential, special, punitive, or exemplary damages arising from the use of the Service.
				</p>
			</div>

			<div class="legal-block">
				<h3>16. Termination</h3>
				<p>
					We may suspend or terminate access to the Service at any time if we reasonably believe
					that a user has violated these Terms or presents legal, security, operational, or
					community risks.
				</p>
				<p>Users may stop using the Service at any time.</p>
			</div>

			<div class="legal-block">
				<h3>17. Changes to These Terms</h3>
				<p>We may revise these Terms periodically.</p>
				<p>Updated versions will be posted on the Service.</p>
				<p>Continued use of the Service after changes become effective constitutes acceptance of the revised Terms.</p>
			</div>
		</section>

		<section class="legal-major-section">
			<h2>Privacy Policy</h2>

			<div class="legal-block">
				<h3>1. Information We Collect</h3>
				<p>We may collect information including:</p>

				<h4>Account Information</h4>
				<ul class="bullets">
					<li>name;</li>
					<li>username;</li>
					<li>email address;</li>
					<li>profile information;</li>
					<li>account preferences.</li>
				</ul>

				<h4>Content Information</h4>
				<ul class="bullets">
					<li>books;</li>
					<li>manuscripts;</li>
					<li>posts;</li>
					<li>comments;</li>
					<li>reviews;</li>
					<li>messages;</li>
					<li>uploaded files;</li>
					<li>support requests.</li>
				</ul>

				<h4>Technical Information</h4>
				<ul class="bullets">
					<li>IP address;</li>
					<li>browser type;</li>
					<li>operating system;</li>
					<li>device information;</li>
					<li>referral information;</li>
					<li>usage data;</li>
					<li>log information.</li>
				</ul>

				<h4>Community Information</h4>
				<ul class="bullets">
					<li>follower relationships;</li>
					<li>reading activity voluntarily shared by users;</li>
					<li>reactions and engagement data;</li>
					<li>participation in groups and discussions.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>2. How We Use Information</h3>
				<p>We use information to:</p>
				<ul class="bullets">
					<li>operate and maintain the Service;</li>
					<li>create and manage accounts;</li>
					<li>provide community features;</li>
					<li>process publishing activities;</li>
					<li>personalize content and recommendations;</li>
					<li>improve functionality and performance;</li>
					<li>respond to support requests;</li>
					<li>prevent abuse, fraud, and security threats;</li>
					<li>comply with legal obligations.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>3. Cookies and Similar Technologies</h3>
				<p>We may use cookies and similar technologies to:</p>
				<ul class="bullets">
					<li>keep users logged in;</li>
					<li>remember preferences;</li>
					<li>maintain security;</li>
					<li>improve website functionality;</li>
					<li>analyze usage and performance.</li>
				</ul>
				<p>You may control cookies through your browser settings.</p>
			</div>

			<div class="legal-block">
				<h3>4. Public Information</h3>
				<p>Certain information may be publicly visible, including:</p>
				<ul class="bullets">
					<li>profile information;</li>
					<li>public posts;</li>
					<li>comments;</li>
					<li>reviews;</li>
					<li>publicly published books;</li>
					<li>community activity intentionally shared by users.</li>
				</ul>
				<p>Public information may be visible to search engines and other indexing services.</p>
				<p>Users should carefully consider what information they choose to make public.</p>
			</div>

			<div class="legal-block">
				<h3>5. Sharing Information</h3>
				<p>ReaderPub does not sell personal information.</p>
				<p>We may share information:</p>
				<ul class="bullets">
					<li>with service providers that help operate the Service;</li>
					<li>with hosting, infrastructure, analytics, payment, communication, and security providers;</li>
					<li>when required by law;</li>
					<li>to protect rights, safety, security, or property;</li>
					<li>in connection with a merger, acquisition, restructuring, or transfer of assets.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>6. Data Retention</h3>
				<p>We retain information only for as long as reasonably necessary to:</p>
				<ul class="bullets">
					<li>provide the Service;</li>
					<li>comply with legal obligations;</li>
					<li>resolve disputes;</li>
					<li>enforce agreements;</li>
					<li>maintain security and backups.</li>
				</ul>
			</div>

			<div class="legal-block">
				<h3>7. Data Security</h3>
				<p>We use reasonable administrative, technical, and organizational measures to protect information.</p>
				<p>However, no system can guarantee absolute security.</p>
			</div>

			<div class="legal-block">
				<h3>8. International Users</h3>
				<p>
					Information may be processed and stored in countries other than the country in which you
					reside.
				</p>
				<p>
					By using the Service, you consent to such processing and transfers as permitted by
					applicable law.
				</p>
			</div>

			<div class="legal-block">
				<h3>9. Your Rights</h3>
				<p>Depending on applicable law, you may have the right to:</p>
				<ul class="bullets">
					<li>access your personal information;</li>
					<li>request correction of inaccurate information;</li>
					<li>request deletion of personal information;</li>
					<li>object to certain processing activities;</li>
					<li>request a copy of information you have provided.</li>
				</ul>
				<p>Requests may be submitted to:</p>
				<p><a href="mailto:support@reader.pub">support@reader.pub</a></p>
			</div>

			<div class="legal-block">
				<h3>10. Children's Privacy</h3>
				<p>
					The Service is not intended for children under the age required by applicable law to
					provide consent for online services.
				</p>
				<p>
					We do not knowingly collect personal information from children without appropriate legal
					authorization.
				</p>
			</div>

			<div class="legal-block">
				<h3>11. Contact Information</h3>
				<p>Questions regarding these Terms or Privacy Policy may be directed to:</p>
				<p><a href="mailto:support@reader.pub">support@reader.pub</a></p>
				<p>ReaderPub</p>
				<p><a href="https://reader.pub">https://reader.pub</a></p>
			</div>
		</section>

		<p class="legal-closing">
			By using ReaderPub or WeBuzz, you acknowledge that you have read, understood, and agreed to
			these Terms of Service and Privacy Policy.
		</p>
	</article>

	<CtaBlock
		title="Last updated on June 2026."
		actions={[
			{ label: "Publish with WePub", href: PUBLISH_URL, external: true },
			{ label: "60K+ books in Catalog", href: BOOKS_URL, external: true, variant: "secondary" },
		]}
	/>
</Base>

<style>
	:global(.terms-hero .hero-copy) {
		max-width: 760px;
	}

	:global(.terms-hero .hero-body) {
		display: grid;
		gap: 14px;
		color: var(--text);
		font-size: 1.125rem;
		line-height: 1.45;
	}

	:global(.terms-hero .hero-body p) {
		margin: 0;
		color: var(--text);
	}

	:global(.terms-hero .hero-body .legal-updated) {
		color: var(--muted);
		font-size: 1rem;
		font-weight: 600;
	}

	:global(.terms-hero .hero-body .terms-hero-green) {
		color: var(--accent);
	}

	.legal-page {
		display: grid;
		gap: 48px;
		max-width: 820px;
	}

	:global(.animation-pass-ready .legal-page[data-reveal]) {
		opacity: 1;
		transform: none;
	}

	.legal-major-section {
		display: grid;
		gap: 24px;
	}

	.legal-major-section > h2 {
		justify-self: start;
		margin: 0;
		text-align: left;
	}

	:global(.content .legal-major-section > h2) {
		justify-self: start;
		margin-right: 0;
		margin-left: 0;
		text-align: left;
	}

	.legal-block {
		display: grid;
		gap: 12px;
	}

	.legal-block > * {
		margin: 0;
	}

	.legal-block h3 {
		font-size: clamp(1.25rem, 2vw, 1.625rem);
		line-height: 1.2;
		color: var(--text);
	}

	.legal-block h4 {
		color: var(--accent);
		font-family: var(--font-body);
		font-size: 1.125rem;
		font-weight: 700;
		line-height: 1.25;
	}

	.legal-block p,
	.legal-block li,
	.legal-closing {
		max-width: none;
		color: var(--text);
		font-size: 1rem;
		line-height: 1.45;
	}

	.legal-block ul {
		display: grid;
		gap: 6px;
		padding-left: 1.4em;
	}

	.legal-block a,
	.legal-closing a {
		color: var(--accent);
	}

	.legal-closing {
		margin: 0;
	}

	@media (max-width: 900px) {
		:global(.terms-hero .hero-body) {
			font-size: 1rem;
		}
	}
</style>
