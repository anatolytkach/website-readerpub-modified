---
import ActionLink from "../components/ActionLink.astro";
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CardGrid from "../components/CardGrid.astro";
import CtaBlock from "../components/sections/CtaBlock.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import Section from "../components/sections/Section.astro";
import { BOOKS_URL, PUBLISH_URL, SITE_NAME } from "../consts";
---

<Base
	title={`Transforming the world of books. | ${SITE_NAME}`}
	description="We make books readable online and keep readers connected. No apps, downloads, or platform lock-in."
>
	<HeroSection
		class="home-hero"
		title="Transforming the world of books."
		lead="E-books are still delivered as files detached from authors, publishers, discussions, and communities."
		image="/images/chain1.webp"
		imageAlt=""
		actions={[
			{ label: "Explore the solution", href: "/platform" },
			{ label: "Read 60K+ books in WeRead", href: BOOKS_URL, external: true, variant: "secondary" },
		]}
		spacerBackgroundPositionY="0%"
	>
		<p class="home-hero-statement hero-body">
			We make books readable online and keep readers connected.
		</p>
		<p class="home-hero-strategy">
			Read instantly. Publish securely. Distribute strategically.
		</p>
		<p class="home-hero-lockin hero-lead">
			No apps, downloads, or platform lock-in.
		</p>
	</HeroSection>

	<Section
		tone="gray"
		title="The challenge:"
		body="Digital publishing made distribution easier, but it did not keep books connected to readers, discussion or long-term discovery."
	>
		<CardGrid columns="3" class="home-problem-grid">
			<Card
				href="/weread"
				icon="readerBook"
				title="Readers"
				body="Reading is digital, but discussion and discovery are fragmented across apps, stores and social networks."
			/>
			<Card
				href="/authors"
				icon="author"
				title="Authors & Publishers"
				body="Authors publish books, but marketplaces often control visibility, readers and the customer relationship."
			/>
			<Card
				href="/institutions"
				icon="library"
				title="Institutions"
				body="Libraries, universities and public organizations publish knowledge that remains hard to find, read and discuss."
			/>
		</CardGrid>
	</Section>

	<Section
		tone="white"
		class="home-file-model-section"
		title="The old file-first model breaks the relationship"
		body="The old publishing model ends when a file is delivered. ReaderPub helps publications remain alive and connected after delivery."
		>
			<div class="home-comparison-grid">
				<article class="card home-list-card home-old-model-card">
					<div class="card-copy">
						<h3>Old model</h3>
						<ul class="home-model-list" style="--home-model-marker-color: var(--text);">
							<li>File uploaded</li>
							<li>Reader downloads</li>
							<li>Discussion moves elsewhere</li>
						<li>Audience becomes invisible</li>
						<li>Relationship ends</li>
					</ul>
					</div>
				</article>
				<article class="card home-list-card home-readerpub-model-card" style="background: linear-gradient(135deg, #eaf9f5 0%, #eaf9f5 18%, var(--card-bg) 100%);">
					<div class="card-copy">
					<h3><span class="home-title-accent">ReaderPub</span> model</h3>
					<ul class="home-model-list">
						<li>Book is published online</li>
						<li>Reader opens instantly in web eReader</li>
						<li>Comments stay connected</li>
						<li>Audience remains visible</li>
						<li>Relationship continues</li>
					</ul>
				</div>
			</article>
		</div>
	</Section>

	<Section tone="white" class="home-web-asset-section" title="What changes when a book becomes a living web asset?">
		<div class="home-comparison-grid">
				<article class="card home-comparison-card" style="background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 18%, var(--card-bg) 100%);">
				<div class="card-copy">
					<h3>Traditional publishing</h3>
					<p class="home-flow home-flow--dark">Publish → Download → Relationship ends</p>
					<p>The old model delivers a file and loses the reader relationship after access begins.</p>
				</div>
			</article>
			<article class="card home-comparison-card">
				<div class="card-copy">
					<h3><span class="home-title-accent">ReaderPub</span> publishing</h3>
					<p class="home-flow">
						Publish <span class="home-flow-arrow">→</span> Discover <span class="home-flow-arrow">→</span> Read <span class="home-flow-arrow">→</span>
						Share &amp; Discuss <span class="home-flow-arrow">→</span> Follow &amp; Engage
					</p>
					<p>ReaderPub keeps the publication alive on the web, connected to readers, discussion and long-term discovery.</p>
				</div>
			</article>
		</div>
	</Section>

	<Section
		id="solution"
		tone="green"
		title="How ReaderPub creates live web publications"
		body="ReaderPub combines web reading, secure publishing, public discussion and structured knowledge tools so books and publications remain alive after launch."
	>
		<CardGrid columns="2" class="home-product-grid">
			<article class="card">
				<div class="card-copy">
					<h3><a class="home-product-link" href="/weread">WeRead</a></h3>
					<p>Books open instantly in the browser instead of being trapped inside apps or files.</p>
				</div>
			</article>
			<article class="card">
				<div class="card-copy">
					<h3><a class="home-product-link" href="/wepub">WePub</a></h3>
					<p>Authors and publishers release secure web-native publications while keeping audience relationships.</p>
				</div>
			</article>
			<article class="card">
				<div class="card-copy">
					<h3 class="home-product-title-line">
						<a class="home-product-link" href="/webuzz">WeBuzz</a>
						<span class="home-product-divider">/</span>
						<a class="home-product-link" href="/wetalk">WeTalk</a>
					</h3>
					<p>Social and private discussions stay connected to books, authors, researchers, and ideas.</p>
				</div>
			</article>
			<article class="card">
				<div class="card-copy">
					<h3><a class="home-product-link" href="/booktree">BookTree</a></h3>
					<p>Serious readers connect books, notes and projects into durable knowledge structures.</p>
				</div>
			</article>
			<article class="card">
				<div class="card-copy">
					<h3><a class="home-product-link" href="/scribe">Scribe</a></h3>
					<p>A specialized AI companion for literature, writing, publishing and ReaderPub.</p>
				</div>
			</article>
		</CardGrid>
	</Section>

	<Section
		tone="white"
		title="ReaderPub is not yet another ebook platform"
	>
		<Fragment slot="body">
			ReaderPub is a web-native publishing network where books and knowledge publications become <strong>living web assets</strong>.
		</Fragment>
		<CardGrid columns="4">
			<Card title="Readable" body="Readers open publications instantly in the browser." />
			<Card title="Discoverable" body="Books and publications have web presence, metadata and shareable URLs." />
			<Card title="Discussable" body="Conversation stays attached to books, authors, fragments and ideas." />
			<Card title="Connected" body="Authors, publishers and institutions can see and engage with their reading audience." />
		</CardGrid>
	</Section>

	<Section tone="green" title="Who benefits from web-native reading?">
		<CardGrid columns="4">
			<Card icon="readerBook" title="Readers" body="They get instant access, context, discussion and better discovery." />
			<Card icon="author" title="Authors" body="They keep more revenue, more audience visibility and more long-term reader connection." />
			<Card icon="publisher" title="Publishers" body="They launch books as active web assets, not isolated product files." />
			<Card icon="library" title="Institutions" body="They turn collections and research into visible public knowledge infrastructure." />
		</CardGrid>
	</Section>

	<CtaBlock
		title="Books should live on the web."
		actions={[
			{ label: "Publish with WePub", href: PUBLISH_URL, external: true },
			{ label: "60K+ books in Catalog", href: BOOKS_URL, external: true, variant: "secondary" },
		]}
	>
		<Fragment slot="body">
			ReaderPub helps books and knowledge publications remain <strong>living web assets</strong> — readable, searchable, shareable, discussable and connected.
		</Fragment>
	</CtaBlock>
</Base>

<style>
	.home-hero-statement {
		max-width: 720px;
		color: var(--accent) !important;
		font-family: var(--font-display) !important;
		font-size: clamp(22.1px, 2.72vw, 32.3px) !important;
		font-weight: 700 !important;
		line-height: 1.12 !important;
	}

	.home-hero-strategy {
		max-width: 720px;
		color: var(--accent);
		font-size: var(--hero-solution-copy-size);
		line-height: 1.45;
	}

	.home-hero-lockin {
		max-width: 720px;
		color: var(--text);
	}

	.home-comparison-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		width: 100%;
	}

	.home-comparison-card,
	.home-list-card {
		min-height: 0;
	}

	:global(.home-readerpub-model-card.home-readerpub-model-card) {
		background: linear-gradient(135deg, #eaf9f5 0%, #eaf9f5 18%, var(--card-bg) 100%) !important;
	}

	.home-flow {
		color: var(--accent);
		font-weight: 700;
	}

	.home-flow--dark,
	.home-flow-arrow {
		color: var(--text);
	}

	.home-title-accent,
	:global(.home-product-grid .card h3) {
		color: var(--accent);
	}

	:global(.home-product-grid .home-product-link) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 34px;
		padding: 7px 12px;
		border: 1px solid var(--border);
		border-radius: var(--radius-control);
		background: var(--button-light-bg);
		color: var(--accent);
		line-height: 1.1;
		text-decoration: none;
		cursor: pointer;
		transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
	}

	:global(.home-product-grid .home-product-link:hover),
	:global(.home-product-grid .home-product-link:focus-visible) {
		transform: translateY(-2px);
		border-color: var(--accent);
		box-shadow: 0 10px 22px rgba(2, 143, 128, 0.18);
		background: var(--button-light-bg);
		color: var(--accent);
	}

	:global(.home-product-grid .home-product-title-line) {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 8px;
	}

	.home-product-divider {
		color: var(--text);
	}

	@media (min-width: 901px) {
		:global(.home-product-grid > .card:last-child) {
			grid-column: 1 / -1;
			justify-self: center;
			width: calc((100% - 18px) / 2);
		}
	}

	:global(.home-problem-grid .card--link:hover),
	:global(.home-problem-grid .card--link:focus-visible) {
		border-color: var(--accent);
		box-shadow: 0 18px 40px rgba(20, 23, 31, 0.12);
	}

	:global(.home-problem-grid .card--link > .card-icon-heading) {
		--card-icon-heading-size: var(--card-inline-icon-size, 56px);
		display: grid;
		grid-template-columns: var(--card-icon-heading-size) minmax(0, 1fr) auto;
		gap: var(--card-icon-gap);
		align-items: center;
		justify-content: stretch;
		width: 100%;
		text-align: left;
	}

	:global(.home-problem-grid .card--link > .card-icon-heading::after) {
		content: "→";
		justify-self: end;
		color: var(--accent);
		font-family: var(--font-body);
		font-size: calc(var(--card-heading-font-size) * 1.25);
		font-weight: 400;
		line-height: 1;
	}

	:global(.home-problem-grid .card--link > .card-icon-heading > .section-icon) {
		grid-column: 1;
		justify-self: start;
	}

	:global(.home-problem-grid .card--link > .card-icon-heading > h3) {
		grid-column: 2;
		max-width: none;
		text-align: left;
	}

	:global(.home-file-model-section .card) {
		--card-tint: #fbfaf8;
	}

	:global(.home-file-model-section) {
		padding-bottom: calc(var(--section-padding) * 0.6667);
	}

	:global(.home-web-asset-section) {
		padding-top: calc(var(--section-padding) * 0.6667);
	}

	@media (orientation: portrait) {
		:global(.home-file-model-section) {
			padding-bottom: var(--section-padding);
		}

		:global(.home-web-asset-section) {
			padding-top: var(--section-padding);
		}
	}

	:global(.home-web-asset-section .section-header),
	:global(.home-web-asset-section .section-header h2) {
		max-width: none;
	}

	@media (min-width: 901px) {
		:global(.home-web-asset-section .section-header h2) {
			white-space: nowrap;
		}
	}

	.home-model-list {
		display: grid;
		gap: 10px;
		padding-left: 1.15rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.5;
	}

	.home-model-list li::marker {
		color: var(--home-model-marker-color, var(--accent));
	}

	:global(.home-old-model-card .home-model-list li::marker) {
		color: var(--text) !important;
	}

	@media (max-width: 900px) {
		.home-comparison-grid {
			grid-template-columns: 1fr;
		}

		.home-model-list {
			text-align: left;
		}
	}
</style>
