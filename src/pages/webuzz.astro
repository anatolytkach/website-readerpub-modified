---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CardGrid from "../components/CardGrid.astro";
import SectionIcon from "../components/SectionIcon.astro";
import CtaBlock from "../components/sections/CtaBlock.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import Section from "../components/sections/Section.astro";
import { SITE_NAME } from "../consts";

const joinConversationAction = { label: "Join the conversation in WeBuzz", href: "https://webuzz.org/", external: true };
const joinWeBuzzCommunityAction = { label: "Join WeBuzz community", href: "/wetalk" };
---

<Base
	title={`WeBuzz | ${SITE_NAME}`}
	description="WeBuzz is the discussion layer for live web publications on ReaderPub."
>
	<HeroSection
		class="webuzz-legacy-hero"
		eyebrow="WeBuzz"
		lead="Every major form of media has a social network. Books largely do not. WeBuzz fills that gap."
		image="/images/webuzz.webp"
		imageAlt="Readers discussing books, authors, and highlighted passages inside a modern literary social network"
		actions={[joinConversationAction]}
		spacerBackgroundPositionY="27%"
	>
		<Fragment slot="title"><span class="webuzz-legacy-product">WeBuzz:</span><br />The missing layer of the book industry</Fragment>
		<Fragment slot="body">WeBuzz is ReaderPub's integrated literary social network, connecting readers, authors, and publishers through discussions, reactions, and shared reading experiences around every book.</Fragment>
	</HeroSection>

	<section class="section section--gray spec-cards-section webuzz-problem-section">
		<h2>Books are the last major medium without a native social layer</h2>
		<div class="card-grid webuzz-comparison-grid">
			<div class="card webuzz-check-card">
				<h3>Video</h3>
				<p>YouTube, TikTok and creator communities</p>
			</div>
			<div class="card webuzz-check-card">
				<h3>Music</h3>
				<p>Spotify, playlists and social sharing</p>
			</div>
			<div class="card webuzz-check-card">
				<h3>Gaming</h3>
				<p>Twitch, Discord and live communities</p>
			</div>
			<div class="card webuzz-books-card">
				<h3>Books</h3>
				<p>Fragmented discussions across Reddit, Facebook, Discord, reviews and private groups</p>
			</div>
		</div>
		<div class="webuzz-fragmented-subsection">
			<header class="section-header">
				<h2>Book discussions are fragmented</h2>
				<p class="section-lead">
					Most conversations about books happen away from the book itself. Discussions become scattered across platforms, communities and private spaces.
				</p>
			</header>
			<CardGrid columns="2" class="webuzz-fragmented-grid">
				<Card title="Reviews are too limited" body="Ratings and reviews rarely capture the depth of real discussion." />
				<Card
					title="Communities are disconnected"
					body="Readers gather in many places, but the publication itself is often absent from the conversation."
				/>
				<Card title="Authors lose visibility" body="Reader reactions frequently happen outside the author's reach." />
				<Card title="Discovery becomes fragmented" body="Valuable conversations are difficult for new readers to find." />
			</CardGrid>
		</div>
	</section>

	<section class="section section--white spec-cards-section webuzz-solution-section section-continuation section-continue-next">
		<div class="webuzz-legacy-overview">
			<h2 class="webuzz-legacy-heading">Reading does not end on the last page.</h2>
			<div class="webuzz-legacy-intro-grid">
				<div class="webuzz-legacy-copy">
					<p class="lede">
						Current platforms separate reading from discussion.
					</p>
					<p class="lede">
						Readers talk about books on social networks, forums and messaging platforms, while the publication itself remains disconnected from the conversation.
					</p>
				</div>
				<div class="card webuzz-legacy-solution-card">
					<p>
						ReaderPub combines publishing, reading, discovery, and discussion in one ecosystem.<br />
						Through WeBuzz, readers can discuss books, follow thoughtful readers, engage with authors, and participate in literary communities.
					</p>
				</div>
			</div>
			<div class="webuzz-overview-card-grid">
				<div class="card webuzz-overview-card">
					<div class="webuzz-overview-card-heading">
						<SectionIcon type="fan" title="Three ways to join the conversation" />
						<h2>Three ways to join the conversation:</h2>
					</div>
					<ul class="bullets webuzz-legacy-list">
						<li>
							<strong>Book Discussions</strong>
							<span>Talk about complete books and reading experiences.</span>
						</li>
						<li>
							<strong>Author Discussions</strong>
							<span>Discuss authors, ideas, and literary influence.</span>
						</li>
						<li>
							<strong>Passage Discussions</strong>
							<span>Start conversations across specific excerpts and quotations.</span>
						</li>
					</ul>
				</div>
				<div class="card webuzz-overview-card webuzz-overview-card--green">
					<div class="webuzz-overview-card-heading">
						<SectionIcon type="noAds" title="No ads in discussion" />
						<h2>No ads in discussion</h2>
					</div>
					<p class="webuzz-overview-note">
						WeBuzz is built for literary conversation, not advertising feeds.
					</p>
					<p class="webuzz-overview-note">
						Discussions around books, authors and passages are not interrupted or shaped by ad-driven social media mechanics.
					</p>
				</div>
			</div>
		</div>
	</section>

	<Section
		tone="green"
		class="webuzz-discussion-lifecycle-section"
		title="Lively publications need lively discussion"
	>
		<Fragment slot="body">
			WeBuzz is not yet another social network.<br />
			It is a discussion board for web-living books and publixations.
		</Fragment>
		<CardGrid columns="4">
			<Card title="Discussion" body="Conversation remains connected to the publication." />
			<Card title="Discovery" body="Readers find books through readers." />
			<Card title="Community" body="Books become gathering points for ongoing engagement." />
			<Card title="Visibility" body="Publishers and authors can see activity inspired by their publications." />
		</CardGrid>
		<div class="webuzz-lifecycle-subsection">
			<header class="section-header">
				<h2>Discussion extends the life of a publication</h2>
				<p class="section-lead">A publication becomes more valuable when readers continue engaging with it after release.</p>
			</header>
			<CardGrid columns="4">
				<Card icon="readerBook" title="Readers" body="Gain places to discuss ideas and recommendations." />
				<Card icon="author" title="Authors" body="Maintain visibility into audience engagement." />
				<Card icon="publisher" title="Publishers" body="Keep books active beyond launch." />
				<Card icon="library" title="Institutions" body="Support learning and discussion across collections." />
			</CardGrid>
		</div>
	</Section>

	<Section
		tone="white"
		hasMedia
		class="webuzz-image-section webuzz-readers-section"
		title="Readers need discussion that stays with the book"
		body="WeBuzz gives readers a place to discuss books, passages, recommendations and ideas without sending the publication out of view."
	>
		<div class="webuzz-image-split">
			<CardGrid columns="2" class="webuzz-image-cards">
				<Card title="Book discussion" body="Readers can respond to the complete work in one shared context." />
				<Card title="Passage discussion" body="Specific ideas and fragments can start focused conversations." />
				<Card title="Recommendations" body="Readers can discover books through people and communities." />
				<Card title="Community activity" body="Discussion becomes part of the publication's visible life." />
			</CardGrid>
			<img
				class="image-block webuzz-section-image"
				src="/images/readers_webuzz.webp"
				alt="Readers discussing the same book while highlighting passages"
				loading="lazy"
				decoding="async"
				width="950"
				height="791"
			/>
		</div>
	</Section>

	<Section
		tone="white"
		hasMedia
		class="webuzz-image-section webuzz-authors-section"
		title="Authors need visibility into real reader response"
		body="Reviews are only one signal. WeBuzz helps authors see discussion about books, scenes, ideas and passages after publication."
	>
		<div class="webuzz-image-split">
			<CardGrid columns="2" class="webuzz-image-cards">
				<Card title="Reader reactions" body="Audience response remains connected to the work that sparked it." />
				<Card title="Questions and context" body="Authors can understand what readers are asking and debating." />
				<Card title="Ongoing presence" body="The author remains visible after the launch window closes." />
				<Card title="Deeper engagement" body="Conversation can move beyond ratings into meaning and interpretation." />
			</CardGrid>
			<img
				class="image-block webuzz-section-image"
				src="/images/author_webuzz.webp"
				alt="Author participating in a discussion with readers around a book"
				loading="lazy"
				decoding="async"
				width="1024"
				height="841"
			/>
		</div>
	</Section>

	<Section
		tone="white"
		hasMedia
		class="webuzz-image-section webuzz-publishers-section"
		title="Publishers need books to remain active"
		body="WeBuzz keeps conversation, discovery and audience activity attached to titles instead of scattering them across separate channels."
	>
		<div class="webuzz-image-split">
			<CardGrid columns="2" class="webuzz-image-cards">
				<Card title="Beyond launch" body="Books can keep accumulating reader activity after release." />
				<Card title="Community discovery" body="New readers can find titles through discussion and recommendation." />
				<Card title="Portfolio visibility" body="Publishers can see where attention is forming across publications." />
				<Card title="Long-term engagement" body="Discussion helps publications stay useful and visible over time." />
			</CardGrid>
			<img
				class="image-block webuzz-section-image"
				src="/images/publisher_webuzz.webp"
				alt="Publisher observing active discussions around multiple books"
				loading="lazy"
				decoding="async"
				width="950"
				height="791"
			/>
		</div>
	</Section>

	<Section
		tone="white"
		hasMedia
		class="webuzz-image-section webuzz-libraries-section"
		title="Institutions need shared spaces for knowledge"
		body="Universities, libraries and organizations can use WeBuzz to support learning, programs and community discussion connected to collections."
	>
		<div class="webuzz-image-split">
			<CardGrid columns="2" class="webuzz-image-cards">
				<Card title="Courses" body="Discussion can continue alongside assigned texts and research materials." />
				<Card title="Library programs" body="Collections can become active places for engagement." />
				<Card title="Book clubs" body="Groups form more easily around instantly accessible books than around files." />
				<Card title="Knowledge communities" body="Researchers and colleagues can explore ideas together within access-controlled publications." />
			</CardGrid>
			<img
				class="image-block webuzz-section-image"
				src="/images/libraries_webuzz.webp"
				alt="University students discussing books in a collaborative reading environment"
				loading="lazy"
				decoding="async"
				width="950"
				height="769"
			/>
		</div>
	</Section>

	<Section
		tone="green"
		class="webuzz-benefits-section"
		title="Who benefits from live book discussions?"
		body="WeBuzz connects books, authors, readers, fragments and literary ideas in one network."
	>
		<CardGrid columns="3" class="webuzz-matters-grid">
			<Card icon="readerBook" title="Readers" body="Discovery becomes social and discussion stays attached to books." />
			<Card
				icon="author"
				title="Authors & Publishers"
				body="Audience activity no longer disappears after the sale. Books gain a longer public life after launch."
			/>
			<Card icon="library" title="Institutions" body="Controlled collections become part of active research and educational workflow." />
		</CardGrid>
	</Section>

	<CtaBlock
		title="Books deserve more than reviews."
		body="WeBuzz keeps a book persistently connected to its discussion, discovery and community."
		actions={[joinWeBuzzCommunityAction]}
	/>
</Base>

<style>
	.webuzz-legacy-product {
		color: var(--accent);
	}

	.webuzz-problem-section {
		--link: var(--accent);
		--card: #fcfaf8;
		--section-flow-gap: 16px;
		--section-block-gap-adjust: 12px;
		display: grid;
		gap: 28px;
		align-items: stretch;
		position: relative;
		padding-top: var(--section-padding) !important;
		padding-bottom: var(--section-padding) !important;
	}

	.webuzz-problem-section > * {
		margin: 0 !important;
	}

	.webuzz-problem-section > .card-grid {
		margin-top: 0 !important;
	}

	.webuzz-problem-section > .webuzz-fragmented-subsection {
		display: grid;
		gap: 28px;
		margin-top: var(--section-padding) !important;
	}

	.webuzz-fragmented-subsection > * {
		margin: 0 !important;
	}

	:global(.webuzz-fragmented-grid) {
		align-items: stretch !important;
		grid-auto-rows: 1fr !important;
	}

	:global(.webuzz-fragmented-grid .card) {
		align-self: stretch !important;
		height: 100% !important;
		min-height: 0 !important;
	}

	.webuzz-problem-section h2 {
		max-width: none;
		font-size: clamp(24px, 3vw, 34px);
		line-height: 1.12;
	}

	.webuzz-problem-section .webuzz-comparison-grid {
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--section-flow-gap);
	}

	.webuzz-problem-section .webuzz-comparison-grid .card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		height: 100%;
		min-height: 130px;
		padding: 18px;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: linear-gradient(135deg, var(--card) 0%, var(--card) 15%, #ffffff 100%);
	}

	.webuzz-problem-section .webuzz-comparison-grid .card h3 {
		padding-right: 54px;
		font-size: clamp(19px, 1.62vw, 26px);
		line-height: 1.15;
	}

	.webuzz-problem-section .webuzz-comparison-grid .card p {
		max-width: 680px;
		color: var(--muted);
		font-size: 16px;
		line-height: 1.28;
	}

	.webuzz-problem-section .webuzz-comparison-grid .card:not(.webuzz-books-card) h3 {
		color: var(--link);
	}

	.webuzz-problem-section .webuzz-books-card::after,
	.webuzz-problem-section .webuzz-comparison-grid .card:not(.webuzz-books-card)::after {
		position: absolute;
		top: 20px;
		right: 22px;
		font-family: "Nunito Sans", sans-serif;
		font-size: 30px;
		font-weight: 800;
		line-height: 1;
	}

	.webuzz-problem-section .webuzz-books-card::after {
		content: "?";
		color: var(--text);
	}

	.webuzz-problem-section .webuzz-comparison-grid .card:not(.webuzz-books-card)::after {
		content: "\2713";
		color: var(--link);
	}

	.webuzz-solution-section {
		--link: var(--accent);
		--section-flow-gap: 16px;
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		align-items: stretch;
		position: relative;
		margin-top: 0 !important;
		padding-top: 58px !important;
		padding-bottom: 58px !important;
	}

	.webuzz-solution-section > * {
		margin: 0 !important;
	}

	@media (orientation: portrait) {
		.webuzz-solution-section {
			padding-top: var(--section-padding) !important;
			padding-bottom: var(--section-padding) !important;
		}
	}

	.webuzz-legacy-overview {
		display: grid;
		gap: 28px;
	}

	.webuzz-legacy-intro-grid,
	.webuzz-overview-card-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 32px;
		width: 100%;
	}

	.webuzz-legacy-intro-grid {
		align-items: center;
	}

	.webuzz-legacy-intro-grid > .card {
		align-self: center;
	}

	.webuzz-overview-card-grid {
		align-items: stretch;
	}

	.webuzz-legacy-copy {
		display: flex;
		flex-direction: column;
		gap: var(--section-flow-gap);
		align-self: center !important;
		min-width: 0;
	}

	.webuzz-legacy-copy > * {
		margin: 0 !important;
	}

	.webuzz-legacy-heading,
	.webuzz-overview-card-heading h2 {
		font-size: clamp(24px, 3vw, 34px);
		line-height: 1.12;
	}

	.webuzz-legacy-heading {
		max-width: none;
		margin: 0 !important;
	}

	.webuzz-legacy-copy > p {
		max-width: 760px;
		font-size: 18px;
		line-height: 1.45;
	}

	.webuzz-legacy-copy > p.lede {
		color: var(--text);
	}

	.webuzz-legacy-copy > p:not(.lede) {
		color: var(--link);
	}

	.webuzz-legacy-solution-card {
		padding: 24px;
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.webuzz-legacy-solution-card p {
		margin: 0 !important;
		color: var(--accent);
		font-size: 18px;
		line-height: 1.45;
	}

	.webuzz-overview-card {
		min-height: 130px;
		padding: 18px;
		border-radius: 10px;
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.webuzz-overview-card--green {
		padding: 24px;
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.webuzz-overview-card-heading {
		--inline-heading-font-size: clamp(19.2px, 2.4vw, 27.2px);
		--inline-icon-size: calc(var(--inline-heading-font-size) * 1.7);
		display: flex !important;
		align-items: center !important;
		justify-content: flex-start !important;
		gap: 18px;
	}

	.webuzz-overview-card-heading h2 {
		flex: 0 1 auto;
		max-width: min(16em, calc(100% - var(--inline-icon-size) - 18px));
		margin: 0 !important;
		font-size: var(--inline-heading-font-size);
		text-align: left;
	}

	:global(.webuzz-overview-card-heading .section-icon) {
		display: block;
		flex: 0 0 auto;
		width: var(--inline-icon-size) !important;
		height: var(--inline-icon-size) !important;
	}

	.webuzz-legacy-list {
		display: grid;
		gap: var(--section-flow-gap);
		max-width: none;
		padding-left: 18px;
	}

	.webuzz-legacy-list li {
		display: grid;
		gap: 6px;
		padding: 0;
		color: var(--muted);
		font-size: 16px;
		line-height: 1.25;
		list-style: disc;
	}

	.webuzz-overview-note {
		margin: var(--section-flow-gap) 0 0 !important;
		color: var(--accent);
		font-size: 18px;
		line-height: 1.45;
	}

	.webuzz-legacy-list li::marker {
		color: var(--accent);
	}

	.webuzz-legacy-list strong {
		color: var(--link);
		font-family: "Playfair Display", serif;
		font-size: 20px;
		line-height: 1.12;
	}

	.webuzz-legacy-list span {
		color: var(--muted);
	}

	.webuzz-comparison-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		width: 100%;
	}

	.webuzz-list-card {
		min-height: 0;
	}

	.webuzz-living-card {
		border-color: var(--accent);
	}

	.webuzz-model-list {
		display: grid;
		gap: 10px;
		padding-left: 1.15rem;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.5;
	}

	.webuzz-model-list li::marker {
		color: var(--accent);
	}

	.webuzz-living-card .webuzz-model-list {
		color: var(--accent);
	}

	:global(.webuzz-discussion-lifecycle-section) {
		--card-tint: #fbfaf8;
	}

	:global(.webuzz-discussion-lifecycle-section .card) {
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.webuzz-lifecycle-subsection {
		display: grid;
		gap: 28px;
		margin-top: var(--section-padding);
	}

	.webuzz-lifecycle-subsection .section-header,
	.webuzz-lifecycle-subsection .section-lead {
		max-width: none;
	}

	:global(.webuzz-benefits-section .webuzz-matters-grid) {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	:global(.webuzz-image-section .section-header) {
		width: 100%;
		max-width: none;
	}

	:global(.webuzz-image-section .section-header h2) {
		max-width: none;
	}

	.webuzz-image-split {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 36%);
		gap: 32px;
		align-items: stretch;
		width: 100%;
	}

	.webuzz-image-cards {
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	:global(.webuzz-authors-section .webuzz-image-cards .card),
	:global(.webuzz-libraries-section .webuzz-image-cards .card) {
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%) !important;
	}

	:global(.webuzz-readers-section .webuzz-image-cards .card),
	:global(.webuzz-publishers-section .webuzz-image-cards .card) {
		background: linear-gradient(135deg, #eef6f5 0%, #eef6f5 18%, #ffffff 100%) !important;
	}

	.webuzz-section-image {
		justify-self: end;
		align-self: center;
		width: 100%;
		max-width: 420px;
		height: 100%;
		object-fit: contain;
	}

	@media (max-width: 1180px) {
		.webuzz-problem-section .webuzz-comparison-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		:global(.webuzz-benefits-section .webuzz-matters-grid) {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}

		.webuzz-image-split {
			grid-template-columns: 1fr;
		}

		.webuzz-section-image {
			justify-self: center;
			height: auto;
		}
	}

	@media (min-width: 901px) {
		:global(.webuzz-image-section .section-header h2) {
			white-space: nowrap;
		}
	}

	@media (max-width: 900px) {
		.webuzz-problem-section .webuzz-comparison-grid,
		:global(.webuzz-benefits-section .webuzz-matters-grid),
		.webuzz-comparison-grid,
		.webuzz-image-cards {
			grid-template-columns: 1fr;
		}

		.webuzz-model-list {
			text-align: left;
		}

	}

	@media (max-width: 760px) {
		.webuzz-legacy-intro-grid,
		.webuzz-overview-card-grid {
			grid-template-columns: 1fr;
		}

		.webuzz-legacy-heading {
			text-align: center;
		}

		.webuzz-overview-card-heading {
			justify-content: center !important;
		}
	}

	@media (orientation: portrait) {
