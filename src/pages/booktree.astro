---
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";
import CardGrid from "../components/CardGrid.astro";
import CtaBlock from "../components/sections/CtaBlock.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import Section from "../components/sections/Section.astro";
import SectionIcon from "../components/SectionIcon.astro";
import { BOOKS_URL, SITE_NAME } from "../consts";

const tryBookTreeAction = { label: "Try BookTree on any book", href: BOOKS_URL, external: true };
const useBookTreeAction = { label: "Use BookTree with any book", href: BOOKS_URL, external: true };
---

<Base
	title={`BookTree | ${SITE_NAME}`}
	description="BookTree helps Living Publications preserve the relationships between publications, notes, references and long-term work."
>
	<HeroSection
		class="booktree-hero"
		eyebrow="BookTree"
		title="BookTree keeps track of what you are trying to learn."
		lead="Knowledge breaks when context is lost. Books, notes and research materials often become disconnected over time."
		body="BookTree gives long-form readers, researchers, students and authors a way to keep context alive across everything they read."
		image="/images/booktree.webp"
		imageAlt="BookTree interface showing manuscripts, source books and notes connected in a structured reading tree."
		actions={[tryBookTreeAction]}
		spacerBackgroundPositionY="36%"
	>
		<Fragment slot="title"><span class="booktree-hero-product" style="color: var(--accent);">BookTree</span> keeps track of what you are trying to learn.</Fragment>
	</HeroSection>

	<Section
		tone="gray"
		title="Books are organized. Knowledge is not."
		body="People may keep their books organized, but the ideas they collect often become scattered across files, notes and projects."
	>
		<CardGrid columns="2" class="booktree-problem-grid">
			<Card title="Ideas scatter" body="Important insights become distributed across many books and sources." />
			<Card title="Context disappears" body="Notes lose meaning when separated from the publications they came from." />
			<Card title="Projects outgrow books" body="Research and writing often require connections across many sources." />
			<Card
				title="Structure becomes manual"
				body="People create folders, documents and spreadsheets just to preserve relationships between ideas."
			/>
		</CardGrid>
	</Section>

	<Section
		tone="white"
		class="booktree-source-section booktree-source-solution-section"
		title="BookTree connects reading to thinking"
	>
		<Fragment slot="body">
			BookTree helps readers organize books, excerpts and notes around research, writing and study.<br />
			Instead of collecting isolated highlights, readers build structured knowledge trees that connect sources, notes, references and projects.<br />
			The focus shifts from storing information to preserving context.
		</Fragment>
		<div class="booktree-source-model-grid">
			<article class="card booktree-source-model-card booktree-without-card">
				<div class="card-copy">
					<h3>Without BookTree</h3>
					<ul class="booktree-source-list">
						<li>Notes remain trapped inside individual books.</li>
						<li>Connections between sources are easy to lose.</li>
						<li>Research becomes harder as projects grow.</li>
						<li>Important discoveries disappear into old highlights.</li>
					</ul>
				</div>
			</article>
			<article class="card booktree-source-model-card booktree-with-card">
				<div class="card-copy">
					<h3>With <span>BookTree</span></h3>
					<ul class="booktree-source-list">
						<li>Sources remain connected to projects.</li>
						<li>Notes stay attached to their context.</li>
						<li>References remain traceable.</li>
						<li>Knowledge accumulates instead of scattering.</li>
					</ul>
				</div>
			</article>
		</div>
	</Section>

	<Section
		tone="green"
		class="booktree-connected-section"
		title="Knowledge should remain connected"
		body="Living Publications create living knowledge. The relationships between books, references and ideas should remain visible over time."
	>
		<CardGrid columns="4">
			<Card title="Context" body="Ideas remain connected to their sources." />
			<Card title="Continuity" body="Knowledge accumulates instead of fragmenting." />
			<Card title="Structure" body="Projects retain relationships across many publications." />
			<Card title="Traceability" body="References remain connected to the work they support." />
		</CardGrid>
		<div class="booktree-connected-subsection">
			<header class="section-header">
				<h2>From isolated books to connected knowledge</h2>
				<p class="section-lead">
					The value of reading rarely comes from a single book. It comes from the relationships between books, notes, ideas and projects accumulated over time. BookTree helps preserve those relationships.
				</p>
			</header>
			<div class="card booktree-flow-card">
				<ul class="flow-chain booktree-flow-chain" aria-label="BookTree knowledge flow">
					<li>Book</li>
					<li>Excerpt</li>
					<li>Note</li>
					<li>Project</li>
					<li>Manuscript</li>
					<li>Knowledge map</li>
				</ul>
			</div>
		</div>
	</Section>

	<Section
		tone="white"
		title="Knowledge compounds through relationships"
		body="The value of reading rarely comes from a single publication. It comes from the connections built across many publications over time."
	>
		<CardGrid columns="4">
			<Card title="Research" body="Connect evidence across many sources." />
			<Card title="Writing" body="Preserve references while developing manuscripts." />
			<Card title="Study" body="Build durable learning structures." />
			<Card title="Discovery" body="Reveal relationships between ideas that would otherwise be lost." />
		</CardGrid>
	</Section>

	<Section tone="green" class="booktree-benefits-section" title="Who benefits from structured knowledge?">
		<p class="section-lead booktree-source-audience-intro">
			BookTree is designed for people who work with ideas over months and years rather than minutes and hours.
		</p>
		<CardGrid columns="3" class="booktree-use-grid">
			<Card icon="author" title="Authors" body="Connect source books, excerpts and notes while working on a manuscript." />
			<Card icon="research" title="Researchers" body="Keep evidence, references and observations organized across many texts." />
			<Card icon="university" title="Students" body="Build study structures that survive beyond one class, book or exam." />
			<Card icon="library" title="Academics" body="Maintain context across courses, papers, citations and long-term projects." />
			<Card icon="reader" title="Journalists" body="Track source material and notes across investigations and background reading." />
			<Card icon="readerBook" title="Lifelong readers" body="Turn serious reading into a personal knowledge structure that grows over time." />
		</CardGrid>
	</Section>

		<CtaBlock
			title="Reading should create knowledge, not fragmentation."
			body="BookTree makes every book a functional component of a larger, structured knowledge system."
			actions={[useBookTreeAction]}
		/>
</Base>

<style>
	:global(.booktree-hero .hero-image) {
		border: 1px solid var(--border);
		border-radius: 10px;
		background: #ffffff;
	}

	:global(.booktree-hero .booktree-hero-product) {
		color: var(--accent) !important;
	}

	:global(.booktree-problem-grid) {
		align-items: start;
		grid-auto-rows: auto;
	}

	:global(.booktree-problem-grid .card) {
		align-self: start;
		height: auto;
		min-height: 0;
	}

	:global(.booktree-source-section.section--white) {
		--section-bg: var(--surface);
	}

	.booktree-source-model-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
		width: 100%;
	}

	.booktree-source-model-card {
		min-height: 0;
	}

	.booktree-without-card {
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.booktree-with-card h3 span {
		color: var(--accent);
	}

	.booktree-source-list {
		list-style: none;
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
	}

	.booktree-source-list li {
		position: relative;
		padding-left: 18px;
		color: var(--muted);
		font-size: 16px;
		line-height: 1.3;
	}

	.booktree-source-list li::before {
		content: "";
		position: absolute;
		top: 0.58em;
		left: 0;
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: var(--accent);
	}

	.booktree-without-card .booktree-source-list li::before {
		background: var(--text);
	}

	.booktree-connected-subsection {
		display: grid;
		gap: 28px;
		margin-top: var(--section-padding);
	}

	.booktree-flow-card {
		min-height: 0;
		padding: 24px;
		border-radius: 10px;
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	.flow-chain {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		align-items: center;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.flow-chain li {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--text);
		font-size: 15.3px;
		line-height: 1.25;
	}

	.flow-chain li:not(:last-child)::after {
		content: "→";
		color: var(--accent);
		font-weight: 700;
	}

	.booktree-flow-chain {
		justify-content: center;
	}

	.booktree-flow-chain li {
		font-size: 18px;
		font-weight: 600;
	}

	.booktree-source-audience-intro {
		margin-top: 0 !important;
	}

	:global(.booktree-benefits-section .booktree-use-grid .card) {
		background: linear-gradient(135deg, #fcfaf8 0%, #fcfaf8 15%, #ffffff 100%);
	}

	@media (max-width: 900px) {
		.booktree-source-model-grid {
			grid-template-columns: 1fr;
		}

		.booktree-flow-chain {
			justify-content: flex-start;
		}
	}
</style>
