---
const target = "/wepub";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta http-equiv="refresh" content={`0;url=${target}`} />
		<link rel="canonical" href={target} />
		<title>Redirecting to WePub</title>
	</head>
	<body>
		<p><a href={target}>Continue to WePub</a></p>
	</body>
</html>
